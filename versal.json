{
    "version": 2,
    "builds": [
      { "src": "api/index.py", "use": "@vercel/python" },
      { "src": "index.html", "use": "@vercel/static" }
    ],
    "routes": [
      { "src": "/api/weather/(.+)", "dest": "api/index.py" },
      { "src": "/api/forecast/(.+)", "dest": "api/index.py" },
      { "src": "/api", "dest": "api/index.py" },
      { "src": "/", "dest": "index.html" }
    ]
  }